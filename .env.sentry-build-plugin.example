# Used by Sentry build scripts to upload sourcemaps / dSYMs in CI.
# Copy this file to `.env.sentry-build-plugin` (which is gitignored) and fill values.
#
# Required for uploads:
# SENTRY_AUTH_TOKEN=...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
#
# Optional:
# SENTRY_URL=https://sentry.io/
#
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=https://sentry.io/

